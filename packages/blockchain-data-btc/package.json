{
  "name": "@asylia/blockchain-data-btc",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "description": "Auditable Bitcoin chain-data TypeScript SDK with normalized balances, UTXOs, transactions, raw tx lookup, broadcast, fiat rates, provider failover, cooldowns, rate limiting, and request deduplication.",
  "license": "MIT",
  "author": "Asylia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Asylia/bitcoin-toolkit.git",
    "directory": "packages/blockchain-data-btc"
  },
  "homepage": "https://github.com/Asylia/bitcoin-toolkit/tree/main/packages/blockchain-data-btc#readme",
  "bugs": {
    "url": "https://github.com/Asylia/bitcoin-toolkit/issues"
  },
  "keywords": [
    "bitcoin",
    "blockchain",
    "blockchain-data",
    "btc",
    "address-balance",
    "utxo",
    "broadcast",
    "raw-transaction",
    "blockstream",
    "mempool",
    "esplora",
    "blockchain.com",
    "blockcypher",
    "coinbase",
    "coingecko",
    "kraken",
    "fiat-rates",
    "failover",
    "rate-limiting",
    "request-deduplication",
    "wallet-sdk",
    "typescript",
    "self-custody",
    "asylia"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "echo \"@asylia/blockchain-data-btc ships sources during the dev phase; no build step yet.\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf .turbo node_modules/.tmp"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
