{
  "name": "@asylia/blockchain-data-btc",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "description": "Asylia Bitcoin chain-data provider — uniform NormalizedAddressBalance API on top of Blockstream.info, Mempool.space, and Blockchain.com with priority-based failover, sliding-window rate limiting, and concurrent-request deduplication. Browser, Deno (Supabase Edge), and Node compatible.",
  "license": "MIT",
  "author": "Asylia",
  "repository": {
    "type": "git",
    "url": "https://github.com/asylia/asylia.io.git",
    "directory": "packages/blockchain-data-btc"
  },
  "homepage": "https://github.com/asylia/asylia.io/tree/main/packages/blockchain-data-btc",
  "bugs": "https://github.com/asylia/asylia.io/issues",
  "keywords": [
    "bitcoin",
    "blockchain",
    "blockchain-data",
    "btc",
    "address-balance",
    "blockstream",
    "mempool",
    "blockchain.com",
    "failover",
    "rate-limiting",
    "asylia"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "echo \"@asylia/blockchain-data-btc ships sources during the dev phase; no build step yet.\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf .turbo node_modules/.tmp"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
