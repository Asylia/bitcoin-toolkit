{
  "name": "@asylia/hw-trezor",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "description": "Auditable Trezor hardware-wallet TypeScript adapter for Connect initialization, environment checks, xpub export, address display, and P2WSH multisig PSBT signing.",
  "license": "MIT",
  "author": "Asylia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Asylia/bitcoin-toolkit.git",
    "directory": "packages/hw-trezor"
  },
  "homepage": "https://github.com/Asylia/bitcoin-toolkit/tree/main/packages/hw-trezor#readme",
  "bugs": {
    "url": "https://github.com/Asylia/bitcoin-toolkit/issues"
  },
  "keywords": [
    "bitcoin",
    "trezor",
    "trezor-connect",
    "hardware-wallet",
    "xpub",
    "bip48",
    "bip380",
    "p2wsh",
    "multisig",
    "psbt",
    "psbt-signing",
    "typescript",
    "self-custody",
    "asylia"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "echo \"@asylia/hw-trezor ships sources during the dev phase; no build step yet.\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf .turbo node_modules/.tmp"
  },
  "peerDependencies": {
    "@asylia/btc-core": "workspace:*"
  },
  "devDependencies": {
    "@asylia/btc-core": "workspace:*",
    "@vitest/coverage-v8": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@trezor/connect-web": "^9.7.3",
    "bs58check": "^4.0.0",
    "tslib": "^2.8.1"
  }
}
