{
  "name": "@asylia/hw-ledger",
  "version": "1.0.1",
  "type": "module",
  "description": "Auditable Ledger hardware-wallet TypeScript adapter for WebHID/Web Bluetooth environment checks, xpub export, wallet-policy registration, address display, and P2WSH multisig PSBT signing.",
  "license": "MIT",
  "author": "Asylia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Asylia/bitcoin-toolkit.git",
    "directory": "packages/hw-ledger"
  },
  "homepage": "https://github.com/Asylia/bitcoin-toolkit/tree/main/packages/hw-ledger#readme",
  "bugs": {
    "url": "https://github.com/Asylia/bitcoin-toolkit/issues"
  },
  "keywords": [
    "bitcoin",
    "ledger",
    "@ledgerhq/ledger-bitcoin",
    "webhid",
    "web-bluetooth",
    "ble",
    "hardware-wallet",
    "wallet-policy",
    "xpub",
    "bip48",
    "p2wsh",
    "multisig",
    "psbt",
    "psbt-signing",
    "typescript",
    "self-custody",
    "asylia"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --out-dir dist --tsconfig tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist .turbo node_modules/.tmp"
  },
  "peerDependencies": {
    "@asylia/btc-core": "^1.0.1"
  },
  "devDependencies": {
    "@asylia/btc-core": "^1.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@ledgerhq/errors": "^6.35.0",
    "@ledgerhq/hw-transport": "^6.35.2",
    "@ledgerhq/hw-transport-web-ble": "^6.34.2",
    "@ledgerhq/hw-transport-webhid": "^6.35.2",
    "@ledgerhq/ledger-bitcoin": "^0.3.1",
    "bs58check": "^4.0.0",
    "tslib": "^2.8.1"
  }
}
