{
  "name": "@asylia/hw-ledger",
  "version": "0.1.0-dev",
  "private": true,
  "type": "module",
  "description": "Asylia Ledger adapter — wallet policy registration, xpub export, and PSBT signing for the Asylia wallet.",
  "license": "MIT",
  "author": "Asylia",
  "repository": {
    "type": "git",
    "url": "https://github.com/asylia/asylia.io.git",
    "directory": "packages/hw-ledger"
  },
  "homepage": "https://github.com/asylia/asylia.io/tree/main/packages/hw-ledger",
  "bugs": "https://github.com/asylia/asylia.io/issues",
  "keywords": [
    "bitcoin",
    "ledger",
    "hardware-wallet",
    "psbt",
    "self-custody",
    "asylia"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "echo \"@asylia/hw-ledger ships sources during the dev phase; no build step yet.\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf .turbo node_modules/.tmp"
  },
  "peerDependencies": {
    "@asylia/btc-core": "workspace:*"
  },
  "devDependencies": {
    "@asylia/btc-core": "workspace:*",
    "@vitest/coverage-v8": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ledgerhq/errors": "^6.34.0",
    "@ledgerhq/hw-transport": "^6.35.1",
    "@ledgerhq/hw-transport-webhid": "^6.35.1",
    "bs58check": "^4.0.0",
    "ledger-bitcoin": "^0.3.0",
    "tslib": "^2.8.1"
  }
}
