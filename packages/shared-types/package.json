{
  "name": "@asylia/shared-types",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "description": "Asylia shared domain types — vault, signer, descriptor, derivation path, UTXO, PSBT proposal.",
  "license": "MIT",
  "author": "Asylia",
  "repository": {
    "type": "git",
    "url": "https://github.com/asylia/asylia.io.git",
    "directory": "packages/shared-types"
  },
  "homepage": "https://github.com/asylia/asylia.io/tree/main/packages/shared-types",
  "bugs": "https://github.com/asylia/asylia.io/issues",
  "keywords": [
    "bitcoin",
    "types",
    "domain",
    "asylia"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "echo \"@asylia/shared-types is types-only; no runtime build step.\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf .turbo node_modules/.tmp"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
