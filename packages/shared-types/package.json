{
  "name": "@asylia/shared-types",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "description": "Shared TypeScript domain contracts for the Asylia Bitcoin self-custody platform: vaults, signers, descriptors, derivation paths, amounts, UTXOs, PSBT proposals, and audit events.",
  "license": "MIT",
  "author": "Asylia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Asylia/bitcoin-toolkit.git",
    "directory": "packages/shared-types"
  },
  "homepage": "https://github.com/Asylia/bitcoin-toolkit/tree/main/packages/shared-types#readme",
  "bugs": {
    "url": "https://github.com/Asylia/bitcoin-toolkit/issues"
  },
  "keywords": [
    "bitcoin",
    "types",
    "typescript",
    "domain",
    "domain-model",
    "multisig",
    "vault",
    "signer",
    "descriptor",
    "utxo",
    "psbt",
    "self-custody",
    "asylia"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "echo \"@asylia/shared-types is types-only; no runtime build step.\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf .turbo node_modules/.tmp"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
